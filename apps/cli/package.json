{
  "name": "harnessforce",
  "version": "1.9.3",
  "description": "Harnessforce CLI — an open-source agent harness for Salesforce development",
  "type": "module",
  "bin": {
    "harnessforce": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/ui/agent-astro.png dist/ui/agent-astro.png",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "harnessforce-core": "^1.9.3"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skyrmionz/harnessforce.git",
    "directory": "apps/cli"
  },
  "license": "MIT"
}
